{
  "identifier": "default",
  "description": "Default capabilities for StudyHub Experiment Agent",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "shell:allow-execute",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "websocket:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete"
  ]
}
