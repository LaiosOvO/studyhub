# ─── StudyHub Infrastructure Configuration ───────────────────────────
# Copy this file to .env and adjust values for your environment.
# All values below are development defaults — CHANGE FOR PRODUCTION.

# ─── PostgreSQL (Application Database) ────────────────────────────────
POSTGRES_USER=studyhub
POSTGRES_PASSWORD=studyhub_dev
POSTGRES_DB=studyhub
POSTGRES_PORT=5432

# ─── Neo4j (Knowledge Graph) ─────────────────────────────────────────
NEO4J_AUTH_PASSWORD=neo4j_dev

# ─── Meilisearch (Full-Text Search) ──────────────────────────────────
MEILI_MASTER_KEY=meili_dev_key

# ─── Valkey (Cache / Message Broker) ─────────────────────────────────
VALKEY_URL=valkey://valkey:6379

# ─── SeaweedFS (S3-compatible Object Storage) ────────────────────────
SEAWEEDFS_S3_ENDPOINT=http://seaweedfs:8333

# ─── Temporal (Workflow Orchestration) ────────────────────────────────
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=temporal_dev
