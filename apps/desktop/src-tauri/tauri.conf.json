{
  "productName": "StudyHub",
  "version": "0.2.0",
  "identifier": "com.studyhub.desktop",
  "build": {
    "devUrl": "http://localhost:3001",
    "frontendDist": "../../../project-7411174/out",
    "beforeDevCommand": "cd ../../project-7411174 && VITE_API_URL=http://101.126.141.165/api npx vite --port 3001",
    "beforeBuildCommand": "cd ../../project-7411174 && npx cross-env BASE_PATH=./ VITE_API_URL=http://101.126.141.165/api npx vite build"
  },
  "app": {
    "windows": [
      {
        "title": "StudyHub",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "exceptionDomain": "101.126.141.165"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
